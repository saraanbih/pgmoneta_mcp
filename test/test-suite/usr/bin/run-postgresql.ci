## along with this program. If not, see <https://www.gnu.org/licenses/>.
set -euo pipefail

export PG_MAX_CONNECTIONS=${PG_MAX_CONNECTIONS:-100}
export PG_SHARED_BUFFERS=${PG_SHARED_BUFFERS:-256MB}
export PG_WORK_MEM=${PG_WORK_MEM:-64kB}
export PG_MAX_PARALLEL_WORKERS=${PG_MAX_PARALLEL_WORKERS:-8}
export PG_EFFECTIVE_CACHE_SIZE=${PG_EFFECTIVE_CACHE_SIZE:-1GB}
export PG_MAX_WAL_SIZE=${PG_MAX_WAL_SIZE:-2GB}
export PG_PASSWORD_ENCRYPTION=${PG_PASSWORD_ENCRYPTION:-scram-sha-256}
export PG_LOG_LEVEL=${PG_LOG_LEVEL:-warning}

if [ -z "${PG_DATABASE}" ] ||
    [ -z "${PG_USER_NAME}" ] || [ -z "${PG_USER_PASSWORD}" ] || [ -z "${PG_REPL_USER_NAME}" ] || [ -z "${PG_REPL_USER_PASSWORD}" ] ||
    [ -z "${PG_NETWORK_MASK}" ]; then
    echo "PG_DATABASE, PG_USER_NAME, PG_USER_PASSWORD, PG_REPL_USER_NAME, PG_REPL_USER_PASSWORD and PG_NETWORK_MASK needs to be defined."
    exit 1
fi

chmod 700 /pgdata/ /pgwal/ /pglog/
chown -R postgres:postgres /pgdata/ /pgwal/ /pglog/

su - postgres -c "/usr/pgsql-18/bin/initdb -k -X /pgwal/ -D /pgdata/ --locale-provider=icu --icu-locale=en-US"

sed -i "s|PG_MAX_CONNECTIONS|$PG_MAX_CONNECTIONS|g" /tmp/postgresql.conf
sed -i "s|PG_SHARED_BUFFERS|$PG_SHARED_BUFFERS|g" /tmp/postgresql.conf
sed -i "s|PG_WORK_MEM|$PG_WORK_MEM|g" /tmp/postgresql.conf
sed -i "s|PG_MAX_PARALLEL_WORKERS|$PG_MAX_PARALLEL_WORKERS|g" /tmp/postgresql.conf
sed -i "s|PG_EFFECTIVE_CACHE_SIZE|$PG_EFFECTIVE_CACHE_SIZE|g" /tmp/postgresql.conf
sed -i "s|PG_MAX_WAL_SIZE|$PG_MAX_WAL_SIZE|g" /tmp/postgresql.conf
sed -i "s|PG_PASSWORD_ENCRYPTION|$PG_PASSWORD_ENCRYPTION|g" /tmp/postgresql.conf
sed -i "s|PG_LOG_LEVEL|$PG_LOG_LEVEL|g" /tmp/postgresql.conf

sed -i "s|PG_DATABASE|$PG_DATABASE|g" /tmp/pg_hba.conf
sed -i "s|PG_USER_NAME|$PG_USER_NAME|g" /tmp/pg_hba.conf
sed -i "s|PG_NETWORK_MASK|$PG_NETWORK_MASK|g" /tmp/pg_hba.conf
sed -i "s|PG_PASSWORD_ENCRYPTION|$PG_PASSWORD_ENCRYPTION|g" /tmp/pg_hba.conf
sed -i "s|PG_REPL_USER_NAME|$PG_REPL_USER_NAME|g" /tmp/pg_hba.conf

su - postgres -c "cp /tmp/postgresql.conf /pgdata/"
su - postgres -c "cp /tmp/pg_hba.conf /pgdata/"

sed -i "s|PG_DATABASE_ENCODING|$PG_DATABASE_ENCODING|g" /tmp/setup.sql
sed -i "s|PG_DATABASE|$PG_DATABASE|g" /tmp/setup.sql
sed -i "s|PG_USER_NAME|$PG_USER_NAME|g" /tmp/setup.sql
sed -i "s|PG_USER_PASSWORD|$PG_USER_PASSWORD|g" /tmp/setup.sql
sed -i "s|PG_REPL_USER_NAME|$PG_REPL_USER_NAME|g" /tmp/setup.sql
sed -i "s|PG_REPL_USER_PASSWORD|$PG_REPL_USER_PASSWORD|g" /tmp/setup.sql


su - postgres -c "/usr/pgsql-18/bin/pg_ctl -D /pgdata/ -w start"
su - postgres -c "/usr/pgsql-18/bin/psql -h /tmp -q -f /tmp/setup.sql postgres"
su - postgres -c "/usr/pgsql-18/bin/pg_ctl -D /pgdata/ stop"

touch /tmp/pgmoneta-postgresql-ready
exec su - postgres -c "/usr/pgsql-18/bin/postgres -D /pgdata/"
